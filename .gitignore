# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# brainstorming visual companion
.superpowers/
.vscode/
.claude/scheduled_tasks.lock

# local working directory (plans, temp files, notes — never committed)
/workdir/

# design handoff package (reference components / screenshots — not part of app build)
/handoff/
app/globals.css.bak

# marketing screenshots — captured against the LIVE addon. Sensitive
# values are redacted by scripts/capture-marketing-screenshots.ts before
# the screenshot is taken (IPs, Amazon order numbers, Bambu device IDs +
# serials), so they're safe to commit.
#
# Latest captures (refreshed every nightly run) and the walkthrough video
# are tracked. Daily archive folders are not — they'd churn git for
# little gain. Logs are local-only.
/marketing/archive/
/marketing/.video-tmp/
/marketing/launchagent.*.log

# test
/test-results/
/playwright-report/
/data/
# lib/data/ contains checked-in static data files (e.g. hms-codes.json)

# HA addon build artifacts (regenerated by ha-addon/build-addon.sh)
ha-addon/haspoolmanager/app/

# local test data (user-private CSVs, sample invoices, etc.)
/testdata/

# iCloud sync duplicates (same content, " 2" suffix)
* 2.ts
* 2.tsx
* 2.js
* 2.jsx
* 2.json
* 2.md
* 2.yml
* 2.yaml
* 2.sh
* 2.css
* 2.sql
