{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(curl:*)",
      "Bash(git:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(rm:*)",
      "Bash(cat:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(python3:*)",
      "Bash(sleep:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(vercel:*)",
      "Bash(chmod:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(gh:*)",
      "Bash(find:*)",
      "Bash(awk:*)",
      "Bash(sort:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(du:*)",
      "Bash(jq:*)",
      "Bash(xargs:*)",
      "Bash(tree:*)",
      "Bash(tar:*)",
      "Bash(diff:*)",
      "Bash(printf:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(sqlite3:*)",
      "Bash(docker info:*)",
      "Bash(docker logs:*)",
      "Bash(docker ps:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(true:*)",
      "Bash(false:*)",
      "Bash(test:*)"
    ],
    "deny": [
      "Bash(cd :*)",
      "Bash(cd\":*)",
      "Bash(cd/:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "gh run list --workflow=ci.yml --branch=main --limit=1 --json conclusion,databaseId,displayTitle --jq '.[] | select(.conclusion == \"failure\") | \"⚠️ CI is RED on main. Latest failure: \\\"\\(.displayTitle)\\\" (run \\(.databaseId)). Inspect with: gh run view \\(.databaseId) --log-failed | tail -50\"' 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/bash-pre-tool-use.py"
          }
        ]
      }
    ]
  }
}
