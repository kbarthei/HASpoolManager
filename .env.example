# SQLite database (single file, default ./data/haspoolmanager.db)
SQLITE_PATH=./data/haspoolmanager.db

# API authentication for HA webhook (Bearer token)
API_SECRET_KEY=

# AI-powered order parsing (optional — disabled when not set)
ANTHROPIC_API_KEY=

# HA addon mode (set automatically by run.sh inside the addon container)
# HA_ADDON=true
