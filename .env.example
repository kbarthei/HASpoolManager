# SQLite database (single file, default ./data/haspoolmanager.db)
SQLITE_PATH=./data/haspoolmanager.db

# API authentication for HA webhook (Bearer token)
API_SECRET_KEY=

# AI-powered order parsing (optional — order parse feature disabled when not set)
ANTHROPIC_API_KEY=

# Sentry error monitoring (optional — disabled when not set)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# HA addon mode (set automatically by run.sh inside the addon container)
# HA_ADDON=true
